<div class="layout layout--col">
  <table class="table lg:table--large">
    <thead>
      <tr class="text--center">
        <th><span class="value--xsmall lg:value--small text--gray-30">Profile</span></th>
        <th><span class="value--xsmall lg:value--small text--gray-30">Enterprise</span></th>
        <th><span class="value--xsmall lg:value--small text--gray-30">Community</span></th>
      </tr>
    </thead>
    <tbody>
      {% for v in merge_variables.versions %}
      <tr class="text--center">
        <td><span class="value--xsmall lg:value--base" data-pixel-perfect="true">{{ v.profile }}</span></td>
        <td><span class="value--xsmall lg:value--base" data-pixel-perfect="true">{{ v.enterprise }}</span></td>
        <td><span class="value--xsmall lg:value--base" data-pixel-perfect="true">{{ v.community }}</span></td>
      </tr>
      {% else %}
      <td><span class="value--xsmall lg:value--base" data-pixel-perfect="true">{{ v.community }}</span></td>
      <td><span class="value--xxsmall p--12" data-pixel-perfect="true">No version data available</span></td>
      {% endfor %}
    </tbody>
  </table>
</div>

<div class="title_bar">
  <span class="title" data-pixel-perfect="true">TrueNAS RV</span>
  <span class="instance">Last refresh: {{ merge_variables.refreshed_at }}</span>
</div>